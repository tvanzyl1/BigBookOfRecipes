@page "/admin"

<PageTitle>Admin</PageTitle>

<section class="section-heading">
    <div>
        <p class="eyebrow">Admin</p>
        <h1>Recipe book maintenance</h1>
        <p>Manage sections, edit recipes, and keep the book tidy.</p>
    </div>
</section>

<div class="section-grid">
    <a class="section-card" href="/admin/sections">
        <h2>Manage sections</h2>
        <p>Create, edit, and remove recipe sections.</p>
        <span>Open section admin</span>
    </a>
    <a class="section-card" href="/admin/recipes">
        <h2>Manage recipes</h2>
        <p>Add recipes, update ingredients, and revise instructions.</p>
        <span>Open recipe admin</span>
    </a>
</div>
